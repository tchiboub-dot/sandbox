# Frontend Environment Variables

# API Configuration (UPDATE FOR PRODUCTION)
# Priority: VITE_API_URL > VITE_API_BASE_URL > /api fallback
VITE_API_URL=http://localhost:5000/api
VITE_API_BASE_URL=http://localhost:5000
VITE_API_TIMEOUT=30000

# WebSocket/Signaling Server (UPDATE FOR PRODUCTION)
VITE_SIGNALING_URL=http://localhost:5001

# WebRTC Configuration
VITE_STUN_SERVER=stun:stun.l.google.com:19302

# Optional TURN servers for production
# VITE_TURN_SERVER=turn:turn.example.com:3478
# VITE_TURN_USERNAME=username
# VITE_TURN_PASSWORD=password

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# Session Configuration
VITE_MAX_SESSION_DURATION=7200
VITE_SESSION_WARNING_TIME=300

# Sandbox Emulator Configuration
# Local development: These are optional, defaults to /api/sandbox endpoints
VITE_SANDBOX_API_URL=http://localhost:5000/api/sandbox
VITE_SANDBOX_POLL_INTERVAL=15000
VITE_SANDBOX_MAX_WAIT=300000

# Production URLs (configure these in Vercel Dashboard)
# VITE_API_URL=https://your-api-server.railway.app/api
# VITE_API_BASE_URL=https://your-api-server.railway.app
# VITE_SIGNALING_URL=https://your-signaling-server.railway.app
# VITE_SANDBOX_API_URL=https://your-sandbox-server.railway.app/api/sandbox
# If backend is deployed in the same Vercel project, omit both API vars and frontend will use /api.
