{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm --workspace frontend run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "installCommand": "npm install",
  "devCommand": "npm --workspace frontend run dev",
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "^/api/sandbox/launch$",
      "dest": "/api/sandbox/launch.js",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "^/api/sandbox/session/(?<sessionId>[^/]+)$",
      "dest": "/api/sandbox/session.js?sessionId=$sessionId",
      "methods": ["GET", "OPTIONS"]
    },
    {
      "src": "^/health$",
      "methods": ["GET"],
      "status": 404
    },
    {
      "src": "^/api(/.*)?$",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
      "status": 404
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "/assets/$1"
    },
    {
      "src": "^/(.*)\\.(?:js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)(?:\\?v=[0-9a-zA-Z\\-._~:/?#\\[\\]@!$&'()*+,;=]*)?$",
      "dest": "/$1.$2",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    }
  ],
  "rewrites": [
    {
      "source": "^/(?!api|assets|health|.*\\.(?:js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)(?:\\?|$))(.*)$",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
