PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloud_device_lab
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=http://localhost:3000
# Optional: allow all Vercel preview/production domains (*.vercel.app)
CORS_ALLOW_VERCEL_PREVIEWS=false

# VM Hosts (comma-separated)
VM_HOST_POOL=localhost:8080,localhost:8081

# WebRTC
STUN_SERVER=stun:stun.l.google.com:19302
